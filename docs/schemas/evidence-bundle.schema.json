{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medre.dev/schemas/evidence-bundle.schema.json",
  "title": "EvidenceBundle",
  "description": "JSON-safe evidence bundle returned by collect_evidence_bundle(). Contains schema_version, status, sections, errors, and limitations.",
  "type": "object",
  "properties": {
    "adapter_status": {
      "description": "Per-adapter runtime status evidence extracted from diagnostics, or null.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/AdapterStatusEvidence" }
        }
      ]
    },
    "collected_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when collection started."
    },
    "command": {
      "type": "string",
      "enum": ["evidence"],
      "description": "Command that produced this bundle. Always 'evidence'."
    },
    "config_source": {
      "type": ["string", "null"],
      "description": "Config source identifier (e.g. 'file', 'env', 'default', 'none')."
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of error messages from sections that encountered errors."
    },
    "evidence_tier": {
      "type": "string",
      "enum": [
        "synthetic",
        "conformance",
        "docker",
        "live_service",
        "hardware"
      ],
      "description": "Evidence provenance tier describing how the evidence was produced. 'live_service' and 'hardware' require explicit opt-in; they are never auto-inferred."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when generation completed."
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Known limitations of the evidence collection process."
    },
    "medre_version": {
      "type": "string",
      "description": "MEDRE package version string (e.g. '0.1.0')."
    },
    "runtime_started": {
      "type": "boolean",
      "description": "Whether the runtime was started to collect live health data."
    },
    "schema_version": {
      "type": "integer",
      "description": "Evidence bundle schema version. Currently 1.",
      "const": 1
    },
    "sections": {
      "type": "object",
      "description": "Collected evidence sections.",
      "properties": {
        "config_summary": {
          "$ref": "#/$defs/EvidenceSection"
        },
        "route_validation": {
          "$ref": "#/$defs/EvidenceSection"
        },
        "diagnostics_snapshot": {
          "$ref": "#/$defs/EvidenceSection"
        },
        "live_health": {
          "$ref": "#/$defs/EvidenceSection"
        },
        "storage": {
          "$ref": "#/$defs/EvidenceSection"
        },
        "recovery": {
          "$ref": "#/$defs/EvidenceSection"
        }
      },
      "additionalProperties": false
    },
    "shutdown_evidence": {
      "description": "Runtime shutdown/cancellation evidence extracted from diagnostics, or null.",
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/ShutdownEvidence" }]
    },
    "convergence_summary": {
      "description": "Per-event convergence diagnostics summary derived from delivery receipts and outbox items, or null.",
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/ConvergenceSummary" }]
    },
    "orphan_report": {
      "description": "Per-event orphan/invalid-lineage report derived from delivery receipts and outbox items, or null.",
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/OrphanReport" }]
    },
    "recovery_summary": {
      "description": "Per-event recovery ownership summary derived from outbox state, or null.",
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/RecoverySummary" }]
    },
    "recovery_ledger": {
      "description": "Per-event startup recovery ledger with ownership actions, or null.",
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/StartupRecoveryLedger" }]
    },
    "status": {
      "type": "string",
      "enum": ["passed", "partial", "error"],
      "description": "Overall evidence collection status."
    }
  },
  "required": [
    "adapter_status",
    "collected_at",
    "command",
    "config_source",
    "errors",
    "evidence_tier",
    "generated_at",
    "limitations",
    "medre_version",
    "runtime_started",
    "schema_version",
    "sections",
    "shutdown_evidence",
    "status"
  ],
  "additionalProperties": false,
  "$defs": {
    "AdapterStatusEvidence": {
      "title": "AdapterStatusEvidence",
      "description": "JSON-safe evidence for a single adapter's runtime status.",
      "type": "object",
      "properties": {
        "adapter_id": {
          "type": "string",
          "description": "Unique adapter identifier."
        },
        "adapter_kind": {
          "type": ["string", "null"],
          "description": "Adapter kind: 'real', 'fake', or null."
        },
        "configured": {
          "type": ["boolean", "null"],
          "description": "Whether transport configuration is present."
        },
        "connected": {
          "type": ["boolean", "null"],
          "description": "True if connected, False if definitely not, null if indeterminate."
        },
        "current_state": {
          "type": ["string", "null"],
          "description": "Lifecycle state value string (e.g. 'ready'), or null."
        },
        "enabled": {
          "type": ["boolean", "null"],
          "description": "Whether the adapter is enabled in config."
        },
        "failure_category": {
          "type": ["string", "null"],
          "description": "Caller-supplied failure category, or null."
        },
        "failure_reason": {
          "type": ["string", "null"],
          "description": "Caller-supplied failure reason, or null."
        },
        "health": {
          "type": ["string", "null"],
          "description": "Normalised health string, or null."
        },
        "operator_status": {
          "type": "string",
          "enum": [
            "disabled",
            "not_configured",
            "configured",
            "starting",
            "connected",
            "degraded",
            "unavailable",
            "stopping",
            "failed",
            "stopped"
          ],
          "description": "Normalised operator-facing status string."
        },
        "transport": {
          "type": ["string", "null"],
          "description": "Transport type (e.g. 'matrix', 'meshtastic'), or null."
        },
        "valid_transitions": {
          "type": ["array", "null"],
          "items": { "type": "string" },
          "description": "Sorted list of valid target state strings, or null."
        }
      },
      "required": [
        "adapter_id",
        "adapter_kind",
        "configured",
        "connected",
        "current_state",
        "enabled",
        "failure_category",
        "failure_reason",
        "health",
        "operator_status",
        "transport",
        "valid_transitions"
      ],
      "additionalProperties": false
    },
    "ShutdownEvidence": {
      "title": "ShutdownEvidence",
      "description": "Immutable shutdown evidence record with deterministic key ordering.",
      "type": "object",
      "properties": {
        "drain_timeout_detected": {
          "type": "boolean",
          "description": "Whether drain timeout was detected from events or reason."
        },
        "evidence_flush_status": {
          "type": ["string", "null"],
          "description": "Status of evidence persistence at shutdown (e.g. 'flushed', 'partial')."
        },
        "in_flight_count": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Number of in-flight deliveries from capacity controller."
        },
        "outbox_shutdown_policy": {
          "type": ["string", "null"],
          "description": "Outbox shutdown policy name. 'resumable' when outbox_counts were supplied; null when no outbox data."
        },
        "pending_outbox_counts": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": { "type": "integer", "minimum": 0 }
            }
          ],
          "description": "Outbox counts filtered to pending statuses, or null."
        },
        "pending_retry_work_total": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Total count of pending retry work items."
        },
        "resume_expected": {
          "type": "boolean",
          "description": "Whether pending outbox work is expected to resume on next start. True when non-terminal outbox work exists and runtime is stopped/stopping."
        },
        "retry_worker_dead_lettered": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Number of retry items that were dead-lettered."
        },
        "retry_worker_failed": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Number of retry items that failed."
        },
        "retry_worker_processed": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Total retry items processed."
        },
        "retry_worker_running": {
          "type": ["boolean", "null"],
          "description": "Whether the retry worker was running at shutdown."
        },
        "retry_worker_succeeded": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Number of retry items that succeeded."
        },
        "runtime_state": {
          "type": ["string", "null"],
          "description": "Runtime lifecycle state value string at shutdown."
        },
        "shutdown_reason": {
          "type": ["string", "null"],
          "description": "Deterministic shutdown reason string, or null."
        },
        "shutdown_status": {
          "type": "string",
          "enum": [
            "running",
            "graceful_stop",
            "cancellation",
            "adapter_failure",
            "drain_timeout",
            "shutdown_pending",
            "stopped",
            "failed"
          ],
          "description": "Canonical shutdown status classification."
        },
        "tasks_cancelled": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Number of tasks cancelled during shutdown, or null."
        }
      },
      "required": [
        "drain_timeout_detected",
        "evidence_flush_status",
        "in_flight_count",
        "outbox_shutdown_policy",
        "pending_outbox_counts",
        "pending_retry_work_total",
        "resume_expected",
        "retry_worker_dead_lettered",
        "retry_worker_failed",
        "retry_worker_processed",
        "retry_worker_running",
        "retry_worker_succeeded",
        "runtime_state",
        "shutdown_reason",
        "shutdown_status",
        "tasks_cancelled"
      ],
      "additionalProperties": false
    },
    "EvidenceSection": {
      "title": "EvidenceSection",
      "description": "A single evidence section with status, optional error, and optional data.",
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "partial", "error", "skipped"],
          "description": "Section collection status."
        },
        "error": {
          "type": ["string", "null"],
          "description": "Error message if the section encountered an error."
        },
        "data": {
          "description": "Section payload data. Null when unavailable or skipped."
        },
        "note": {
          "type": ["string", "null"],
          "description": "Explanatory note (e.g. skip reason)."
        }
      },
      "required": ["status", "error", "data"]
    },
    "ConvergenceSummary": {
      "title": "ConvergenceSummary",
      "description": "Aggregate convergence summary across all delivery targets for a single event.",
      "type": "object",
      "properties": {
        "evidence_bundle_ref": {
          "type": ["string", "null"],
          "description": "Reserved cross-reference to the evidence bundle. Currently null."
        },
        "orphan_count": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Count of orphan records. Null in convergence_summary; orphan_report is the authoritative source."
        },
        "severity_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "description": "Count of targets per severity level (safe, degraded, inconsistent)."
        },
        "targets": {
          "type": "array",
          "items": { "$ref": "#/$defs/DeliveryTargetConvergence" },
          "description": "Per-target convergence results, deterministically sorted by group key."
        },
        "total_targets": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of unique delivery targets examined."
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Aggregate diagnostic messages."
        },
        "worst_severity": {
          "type": ["string", "null"],
          "enum": ["safe", "degraded", "inconsistent", null],
          "description": "The worst convergence severity across all targets, or null if no targets."
        }
      },
      "required": [
        "evidence_bundle_ref",
        "orphan_count",
        "severity_counts",
        "targets",
        "total_targets",
        "warnings",
        "worst_severity"
      ],
      "additionalProperties": false
    },
    "DeliveryTargetConvergence": {
      "title": "DeliveryTargetConvergence",
      "description": "Convergence state for a single delivery target.",
      "type": "object",
      "properties": {
        "delivery_plan_id": {
          "type": "string",
          "description": "Delivery plan grouping key. Empty string when absent."
        },
        "target_adapter": {
          "type": "string",
          "description": "Adapter name."
        },
        "target_channel": {
          "type": ["string", "null"],
          "description": "Channel identifier or null."
        },
        "outbox_status": {
          "type": ["string", "null"],
          "description": "Status of the outbox item, or null if no outbox item."
        },
        "latest_receipt_status": {
          "type": ["string", "null"],
          "description": "Status of the latest receipt, or null if no receipt."
        },
        "latest_receipt_id": {
          "type": ["string", "null"],
          "description": "Receipt ID of the latest receipt, or null."
        },
        "latest_attempt_number": {
          "type": ["integer", "null"],
          "description": "Attempt number from the latest receipt, or null."
        },
        "severity": {
          "type": "string",
          "enum": ["safe", "degraded", "inconsistent"],
          "description": "Convergence severity classification."
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Diagnostic messages explaining the classification."
        },
        "outbox_id": {
          "type": ["string", "null"],
          "description": "Outbox item ID, or null."
        }
      },
      "required": [
        "delivery_plan_id",
        "target_adapter",
        "target_channel",
        "outbox_status",
        "latest_receipt_status",
        "latest_receipt_id",
        "latest_attempt_number",
        "severity",
        "warnings",
        "outbox_id"
      ],
      "additionalProperties": false
    },
    "OrphanFinding": {
      "title": "OrphanFinding",
      "description": "A single orphan or invalid-lineage finding.",
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "orphaned_outbox",
            "orphaned_parent_receipt",
            "cross_plan_parent",
            "cross_event_parent",
            "missing_delivery_plan_id",
            "dead_lettered_retryable_mismatch",
            "recovered_not_progressed",
            "repeatedly_reclaimed",
            "reclaimed_then_terminal",
            "reclaimed_then_orphaned"
          ],
          "description": "Category of finding."
        },
        "severity": {
          "type": "string",
          "enum": ["inconsistent", "degraded"],
          "description": "Convergence severity string."
        },
        "record_id": {
          "type": "string",
          "description": "Identifier of the affected record (outbox_id or receipt_id)."
        },
        "record_type": {
          "type": "string",
          "enum": ["outbox", "receipt"],
          "description": "Type of the affected record."
        },
        "details": {
          "type": "string",
          "description": "Human-readable diagnostic message."
        },
        "extra": {
          "type": "object",
          "description": "Additional JSON-safe context (event IDs, plan IDs, statuses).",
          "additionalProperties": true
        }
      },
      "required": [
        "kind",
        "severity",
        "record_id",
        "record_type",
        "details",
        "extra"
      ],
      "additionalProperties": false
    },
    "OrphanReport": {
      "title": "OrphanReport",
      "description": "Aggregate orphan/invalid-lineage report.",
      "type": "object",
      "properties": {
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/OrphanFinding" },
          "description": "Individual findings, deterministically sorted."
        },
        "total_findings": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of findings."
        },
        "severity_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "description": "Count of findings per severity level."
        },
        "worst_severity": {
          "type": ["string", "null"],
          "enum": ["safe", "degraded", "inconsistent", null],
          "description": "Worst severity among findings, or null if empty."
        },
        "summary": {
          "type": "string",
          "description": "Human-readable summary line."
        }
      },
      "required": [
        "findings",
        "total_findings",
        "severity_counts",
        "worst_severity",
        "summary"
      ],
      "additionalProperties": false
    },
    "RecoverySummary": {
      "title": "RecoverySummary",
      "description": "Deterministic recovery ownership summary with consistency validation.",
      "type": "object",
      "properties": {
        "recoverable_items": { "type": "integer", "minimum": 0 },
        "claimed_items": { "type": "integer", "minimum": 0 },
        "reclaimed_items": { "type": "integer", "minimum": 0 },
        "skipped_items": { "type": "integer", "minimum": 0 },
        "abandoned_items": { "type": "integer", "minimum": 0 },
        "unrecoverable_items": { "type": "integer", "minimum": 0 },
        "total_items": { "type": "integer", "minimum": 0 },
        "consistency_valid": { "type": "boolean" },
        "by_source": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "recovery_run_id": { "type": ["string", "null"] }
      },
      "required": [
        "recoverable_items",
        "claimed_items",
        "reclaimed_items",
        "skipped_items",
        "abandoned_items",
        "unrecoverable_items",
        "total_items",
        "consistency_valid",
        "by_source",
        "recovery_run_id"
      ],
      "additionalProperties": false
    },
    "StartupRecoveryLedger": {
      "title": "StartupRecoveryLedger",
      "description": "Append-only startup recovery ownership ledger.",
      "type": "object",
      "properties": {
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/RecoveryOwnershipAction" }
        },
        "generated_at": { "type": "string", "format": "date-time" },
        "recovery_run_id": { "type": ["string", "null"] },
        "startup_timestamp": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      },
      "required": [
        "actions",
        "generated_at",
        "recovery_run_id",
        "startup_timestamp"
      ],
      "additionalProperties": false
    },
    "RecoveryOwnershipAction": {
      "title": "RecoveryOwnershipAction",
      "description": "A single recovery ownership action recorded in the ledger.",
      "type": "object",
      "properties": {
        "delivery_plan_id": { "type": "string" },
        "event_id": { "type": "string" },
        "outbox_id": { "type": "string" },
        "ownership_action": { "type": "string" },
        "prior_status": { "type": "string" },
        "reason": { "type": "string" },
        "recovered_status": { "type": "string" },
        "recovery_run_id": { "type": ["string", "null"] },
        "recovery_source": { "type": "string" },
        "startup_timestamp": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "worker_identity": { "type": ["string", "null"] }
      },
      "required": [
        "delivery_plan_id",
        "event_id",
        "outbox_id",
        "ownership_action",
        "prior_status",
        "reason",
        "recovered_status",
        "recovery_run_id",
        "recovery_source",
        "startup_timestamp",
        "timestamp",
        "worker_identity"
      ],
      "additionalProperties": false
    }
  }
}
