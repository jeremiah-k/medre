# MEDRE Docker Deployment Environment Variables
#
# Copy this file to .env and replace placeholder values before running
# docker compose up.  This file is loaded by Docker Compose, Kubernetes
# (via ConfigMap/Secret), or similar container runtimes.  MEDRE does not
# read .env files itself — it reads environment variables set by the
# container runtime.
#
# MEDRE_HOME is set to /opt/medre inside the container. Mount a volume
# at /opt/medre for persistent state, crypto keys, and runtime data.

# --- General ---
# Root data directory inside the container (mapped via Docker volume)
MEDRE_HOME=/opt/medre

# Log verbosity: DEBUG, INFO, WARNING, ERROR
MEDRE_LOG_LEVEL=INFO

# --- Matrix Adapter ---
MEDRE_MATRIX_ENABLED=true
MEDRE_MATRIX_HOMESERVER=https://matrix.example.com
MEDRE_MATRIX_USER_ID=@bot:example.com
# Generate via: curl -X POST https://matrix.example.com/_matrix/client/v3/login
MEDRE_MATRIX_ACCESS_TOKEN=syt_secret_token_here
# Comma-separated list of Matrix room IDs to bridge
MEDRE_MATRIX_ROOM_ALLOWLIST=!room:example.com
# Encryption policy: plaintext (default), e2ee_required, e2ee_optional
# E2EE store path is derived automatically under MEDRE_HOME/state/adapters/<adapter_id>/matrix/store
#MEDRE_MATRIX_ENCRYPTION_MODE=plaintext

# --- Meshtastic Adapter ---
MEDRE_MESHTASTIC_ENABLED=true
# Connection type: serial, tcp, ble, fake
MEDRE_MESHTASTIC_CONNECTION_TYPE=serial
# Serial device path (passed through from host via --device /dev/ttyACM0)
MEDRE_MESHTASTIC_SERIAL_PORT=/dev/ttyACM0
